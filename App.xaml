<Application x:Class="ACGCET_Admin.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ACGCET_Admin"
             xmlns:converters="clr-namespace:ACGCET_Admin.Converters"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <md:BundledTheme BaseTheme="Light" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ══ CONVERTERS ═══════════════════════════════════════ -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:InverseBoolToVisibilityConverter  x:Key="InverseBoolToVisibilityConverter"/>
            <converters:InverseBooleanConverter           x:Key="InverseBooleanConverter"/>
            <converters:SeverityToBackgroundConverter     x:Key="SeverityToBgConverter"/>
            <converters:SeverityToForegroundConverter     x:Key="SeverityToFgConverter"/>
            <converters:ActionTypeToBackgroundConverter   x:Key="ActionTypeToBgConverter"/>
            <converters:ActionTypeToForegroundConverter   x:Key="ActionTypeToFgConverter"/>
            <converters:LockToBackgroundConverter         x:Key="LockToBgConverter"/>
            <converters:LockToForegroundConverter         x:Key="LockToFgConverter"/>

            <!-- ══ DESIGN TOKENS ════════════════════════════════════ -->
            <SolidColorBrush x:Key="PrimaryBrush"      Color="#7C3AED"/>
            <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#6D28D9"/>
            <SolidColorBrush x:Key="PrimaryLightBrush" Color="#EDE9FE"/>
            <SolidColorBrush x:Key="PrimaryFaintBrush" Color="#F5F3FF"/>
            <SolidColorBrush x:Key="PrimaryTextBrush"  Color="#5B21B6"/>
            <SolidColorBrush x:Key="AppFgBrush"        Color="#09090B"/>
            <SolidColorBrush x:Key="AppMutedBrush"     Color="#71717A"/>
            <SolidColorBrush x:Key="AppBorderBrush"    Color="#E4E4E7"/>
            <SolidColorBrush x:Key="AppBgBrush"        Color="#FAFAFA"/>
            <SolidColorBrush x:Key="AppCardBrush"      Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AppSubtleBrush"    Color="#F4F4F5"/>
            <SolidColorBrush x:Key="DestructiveBrush"  Color="#EF4444"/>
            <SolidColorBrush x:Key="SuccessBrush"      Color="#22C55E"/>
            <SolidColorBrush x:Key="WarningBrush"      Color="#F97316"/>

            <!-- ══ FONT ══════════════════════════════════════════════ -->
            <!-- Google Sans → falls back to Segoe UI Variable Display on machines without it -->
            <FontFamily x:Key="AppFont">pack://application:,,,/Resources/Fonts/#Google Sans,Google Sans,Segoe UI Variable Display,Segoe UI</FontFamily>

            <!-- ══ FONT — TextBlock only (safe, doesn't conflict with MD) ══ -->
            <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignBody2TextBlock}">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            </Style>

            <!-- ══ TEXTBOX — MD outlined + font/size override ════════ -->
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize"   Value="13"/>
                <Setter Property="Margin"     Value="0 4"/>
            </Style>

            <!-- ══ COMBOBOX — MD outlined + font/size override ═══════ -->
            <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize"   Value="13"/>
                <Setter Property="Margin"     Value="0 4"/>
            </Style>

            <!-- ══ DATAGRID — MD base + our overrides ════════════════ -->
            <Style TargetType="DataGrid" BasedOn="{StaticResource MaterialDesignDataGrid}">
                <Setter Property="BorderThickness"               Value="0"/>
                <Setter Property="RowBackground"                 Value="White"/>
                <Setter Property="AlternatingRowBackground"      Value="#F5F3FF"/>
                <Setter Property="GridLinesVisibility"           Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush"      Value="#EDE9FE"/>
                <Setter Property="HeadersVisibility"             Value="Column"/>
                <Setter Property="SelectionMode"                 Value="Single"/>
                <Setter Property="SelectionUnit"                 Value="FullRow"/>
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto"/>
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
                <Setter Property="FontSize"                      Value="13"/>
                <Setter Property="FontFamily"                    Value="{StaticResource AppFont}"/>
                <Setter Property="RowHeight"                     Value="36"/>
                <Setter Property="CanUserReorderColumns"         Value="False"/>
                <Setter Property="CanUserResizeRows"             Value="False"/>
                <Setter Property="EnableRowVirtualization"       Value="True"/>
                <Setter Property="EnableColumnVirtualization"    Value="True"/>
                <Setter Property="md:DataGridAssist.CellPadding" Value="13 8 8 8"/>
            </Style>

            <Style TargetType="DataGridColumnHeader"
                   BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                <Setter Property="Background"               Value="#F5F3FF"/>
                <Setter Property="Foreground"               Value="#5B21B6"/>
                <Setter Property="FontWeight"               Value="SemiBold"/>
                <Setter Property="FontSize"                 Value="12"/>
                <Setter Property="FontFamily"               Value="{StaticResource AppFont}"/>
                <Setter Property="Padding"                  Value="12 9"/>
                <Setter Property="BorderBrush"              Value="#E4E4E7"/>
                <Setter Property="BorderThickness"          Value="0 0 0 1"/>
            </Style>

            <Style TargetType="DataGridRow"
                   BasedOn="{StaticResource MaterialDesignDataGridRow}">
                <Setter Property="FontSize"   Value="13"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F5F3FF"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#EDE9FE"/>
                        <Setter Property="Foreground" Value="#09090B"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Cell left-padding so records don't hug the edge -->
            <Style TargetType="DataGridCell">
                <Setter Property="BorderThickness"  Value="0"/>
                <Setter Property="FontFamily"       Value="{StaticResource AppFont}"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background"  Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Foreground"  Value="#09090B"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ══ NAMED BUTTON STYLES (sharp, smaller) ══════════════ -->
            <!-- Primary filled purple -->
            <Style x:Key="PrimaryButton" TargetType="Button"
                   BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background"          Value="#7C3AED"/>
                <Setter Property="Foreground"          Value="White"/>
                <Setter Property="BorderThickness"     Value="0"/>
                <Setter Property="md:ButtonAssist.CornerRadius" Value="0"/>
                <Setter Property="md:ElevationAssist.Elevation" Value="Dp0"/>
                <Setter Property="FontSize"            Value="12"/>
                <Setter Property="FontWeight"          Value="Medium"/>
                <Setter Property="FontFamily"          Value="{StaticResource AppFont}"/>
                <Setter Property="Height"              Value="28"/>
                <Setter Property="Padding"             Value="14 0"/>
            </Style>

            <!-- Outlined purple -->
            <Style x:Key="OutlineButton" TargetType="Button"
                   BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="BorderBrush"         Value="#7C3AED"/>
                <Setter Property="Foreground"          Value="#7C3AED"/>
                <Setter Property="BorderThickness"     Value="1"/>
                <Setter Property="md:ButtonAssist.CornerRadius" Value="0"/>
                <Setter Property="FontSize"            Value="12"/>
                <Setter Property="FontFamily"          Value="{StaticResource AppFont}"/>
                <Setter Property="Height"              Value="28"/>
                <Setter Property="Padding"             Value="14 0"/>
            </Style>

            <!-- Subtle outline (muted) -->
            <Style x:Key="SubtleButton" TargetType="Button"
                   BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="BorderBrush"         Value="#E4E4E7"/>
                <Setter Property="Foreground"          Value="#52525B"/>
                <Setter Property="BorderThickness"     Value="1"/>
                <Setter Property="md:ButtonAssist.CornerRadius" Value="0"/>
                <Setter Property="FontSize"            Value="12"/>
                <Setter Property="FontFamily"          Value="{StaticResource AppFont}"/>
                <Setter Property="Height"              Value="28"/>
                <Setter Property="Padding"             Value="14 0"/>
            </Style>

            <!-- Destructive outlined -->
            <Style x:Key="DangerButton" TargetType="Button"
                   BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="BorderBrush"         Value="#E4E4E7"/>
                <Setter Property="Foreground"          Value="#EF4444"/>
                <Setter Property="BorderThickness"     Value="1"/>
                <Setter Property="md:ButtonAssist.CornerRadius" Value="0"/>
                <Setter Property="FontSize"            Value="12"/>
                <Setter Property="FontFamily"          Value="{StaticResource AppFont}"/>
                <Setter Property="Height"              Value="28"/>
                <Setter Property="Padding"             Value="14 0"/>
            </Style>

            <!-- Icon-only small button -->
            <Style x:Key="IconButton" TargetType="Button"
                   BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="BorderBrush"         Value="#E4E4E7"/>
                <Setter Property="Foreground"          Value="#71717A"/>
                <Setter Property="BorderThickness"     Value="1"/>
                <Setter Property="md:ButtonAssist.CornerRadius" Value="0"/>
                <Setter Property="Width"               Value="28"/>
                <Setter Property="Height"              Value="28"/>
                <Setter Property="Padding"             Value="0"/>
            </Style>

            <!-- Sub-section sidebar nav button -->
            <Style x:Key="SubNavButton" TargetType="Button"
                   BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="HorizontalAlignment"        Value="Stretch"/>
                <Setter Property="Margin"                     Value="6 2"/>
                <Setter Property="Height"                     Value="40"/>
                <Setter Property="Padding"                    Value="14 0"/>
                <Setter Property="Background"                 Value="Transparent"/>
                <Setter Property="BorderThickness"            Value="0"/>
                <Setter Property="Foreground"                 Value="#52525B"/>
                <Setter Property="FontSize"                   Value="13"/>
                <Setter Property="FontWeight"                 Value="Normal"/>
                <Setter Property="FontFamily"                 Value="{StaticResource AppFont}"/>
                <Setter Property="md:ButtonAssist.CornerRadius" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F5F3FF"/>
                        <Setter Property="Foreground" Value="#7C3AED"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Back nav button -->
            <Style x:Key="BackNavButton" TargetType="Button"
                   BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="HorizontalAlignment"        Value="Stretch"/>
                <Setter Property="Margin"                     Value="6 2"/>
                <Setter Property="Height"                     Value="38"/>
                <Setter Property="Padding"                    Value="14 0"/>
                <Setter Property="Background"                 Value="Transparent"/>
                <Setter Property="BorderThickness"            Value="0"/>
                <Setter Property="Foreground"                 Value="#EF4444"/>
                <Setter Property="FontSize"                   Value="13"/>
                <Setter Property="FontFamily"                 Value="{StaticResource AppFont}"/>
                <Setter Property="md:ButtonAssist.CornerRadius" Value="0"/>
            </Style>

            <!-- ══ SKELETON SHIMMER ══════════════════════════════════ -->
            <Style x:Key="SkeletonShimmer" TargetType="ContentControl">
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContentControl">
                            <Grid ClipToBounds="True">
                                <Rectangle Fill="#EDE9FE"/>
                                <Rectangle Width="260">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="Transparent" Offset="0"/>
                                            <GradientStop Color="#70FFFFFF"   Offset="0.5"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                    <Rectangle.RenderTransform>
                                        <TranslateTransform x:Name="ShimmerX" X="-260"/>
                                    </Rectangle.RenderTransform>
                                    <Rectangle.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="ShimmerX"
                                                                     Storyboard.TargetProperty="X"
                                                                     From="-260" To="1600" Duration="0:0:1.5"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Rectangle.Triggers>
                                </Rectangle>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
