<UserControl x:Class="ACGCET_Admin.Views.EntryReport.EntryReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:ACGCET_Admin.ViewModels.EntryReport"
             xmlns:views="clr-namespace:ACGCET_Admin.Views.EntryReport"
             xmlns:dashboardViews="clr-namespace:ACGCET_Admin.ViewModels.Dashboard"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:EntryReportViewModel}"
             d:DesignHeight="768" d:DesignWidth="1366">

    <UserControl.Resources>
        <DataTemplate DataType="{x:Type viewmodels:StudentEntryReportViewModel}">
            <views:StudentEntryReportView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:InternalMarkEntryReportViewModel}">
            <views:InternalMarkEntryReportView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ExamApplyEntryReportViewModel}">
            <views:ExamApplyEntryReportView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ExternalMarkEntryReportViewModel}">
            <views:ExternalMarkEntryReportView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ResultEntryReportViewModel}">
            <views:ResultEntryReportView/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="#FAFAFA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sub-Sidebar ──────────────────────────────────── -->
        <Border Grid.Column="0" Background="White"
                BorderThickness="0 0 1 0" BorderBrush="#E4E4E7"
                ClipToBounds="True">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top"
                        Padding="16 16 16 14"
                        BorderThickness="0 0 0 1" BorderBrush="#E4E4E7">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ChartBox" Width="16" Height="16"
                                         Foreground="#7C3AED" VerticalAlignment="Center"/>
                            <TextBlock Text="ENTRY REPORTS" FontSize="11" FontWeight="Bold"
                                       Foreground="#7C3AED" Margin="8 0 0 0" VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"/>
                        </StackPanel>
                        <TextBlock Text="Data Entry Status Reports" FontSize="11"
                                   Foreground="#71717A" Margin="0 3 0 0"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- Footer — back uses Window DataContext since EntryReport is nested differently -->
                <Border DockPanel.Dock="Bottom"
                        Padding="6 8" BorderThickness="0 1 0 0" BorderBrush="#E4E4E7">
                    <Button Style="{StaticResource BackNavButton}"
                            Command="{Binding DataContext.NavigateCommand,
                                RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                            CommandParameter="Home">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ArrowLeft" Width="15" Height="15"
                                         Margin="0 0 8 0" VerticalAlignment="Center"
                                         Foreground="#EF4444"/>
                            <TextBlock Text="Back to Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Nav items -->
                <StackPanel Margin="0 8 0 0">
                    <TextBlock Text="REPORT TYPES" FontSize="10" FontWeight="Bold"
                               Foreground="#A1A1AA" Margin="16 10 0 4"
                               FontFamily="Segoe UI Variable Display, Segoe UI"/>

                    <Button Style="{StaticResource SubNavButton}"
                            Command="{Binding ShowStudentEntryCommand}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="AccountGroup" Width="15" Height="15"
                                         Margin="0 0 10 0" VerticalAlignment="Center" Foreground="#22C55E"/>
                            <TextBlock Text="Student Entry Report" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SubNavButton}"
                            Command="{Binding ShowInternalMarkEntryCommand}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ClipboardText" Width="15" Height="15"
                                         Margin="0 0 10 0" VerticalAlignment="Center" Foreground="#F97316"/>
                            <TextBlock Text="Internal Mark Entry" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SubNavButton}"
                            Command="{Binding ShowExamApplyEntryCommand}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="FileDocument" Width="15" Height="15"
                                         Margin="0 0 10 0" VerticalAlignment="Center" Foreground="#3B82F6"/>
                            <TextBlock Text="Exam Apply Entry" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SubNavButton}"
                            Command="{Binding ShowExternalMarkEntryCommand}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ClipboardCheck" Width="15" Height="15"
                                         Margin="0 0 10 0" VerticalAlignment="Center" Foreground="#EF4444"/>
                            <TextBlock Text="External Mark Entry" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SubNavButton}"
                            Command="{Binding ShowResultEntryCommand}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ChartBar" Width="15" Height="15"
                                         Margin="0 0 10 0" VerticalAlignment="Center" Foreground="#7C3AED"/>
                            <TextBlock Text="Result Entry Report" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Content Area ─────────────────────────────────── -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="28 24"/>
    </Grid>
</UserControl>
