<UserControl x:Class="ACGCET_Admin.Views.Application.ApplicationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:ACGCET_Admin.ViewModels.Application"
             xmlns:views="clr-namespace:ACGCET_Admin.Views.Application"
             xmlns:dashboardViews="clr-namespace:ACGCET_Admin.Views.Dashboard"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:ApplicationViewModel}"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <DataTemplate DataType="{x:Type viewmodels:ClassWiseStudentsViewModel}">
            <views:ClassWiseStudentsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ClassWiseSubjectCodeViewModel}">
            <views:ClassWiseSubjectCodeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ClassInternalMarkReportViewModel}">
            <views:ClassInternalMarkReportView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ClassWiseHallTicketViewModel}">
            <views:ClassWiseHallTicketView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:TimetablePrintViewModel}">
            <views:TimetablePrintView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:YearWiseIntExtReportViewModel}">
            <views:YearWiseIntExtReportView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ClassWiseIntExtReportViewModel}">
            <views:ClassWiseIntExtReportView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:A4ResultPrintViewModel}">
            <views:A4ResultPrintView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:RevaluationReportViewModel}">
            <views:RevaluationReportView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:PassingCreditReportViewModel}">
            <views:PassingCreditReportView/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="#FAFAFA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sub-Sidebar ──────────────────────────────────── -->
        <Border Grid.Column="0" Background="White"
                BorderThickness="0 0 1 0" BorderBrush="#E4E4E7"
                ClipToBounds="True">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top"
                        Padding="16 16 16 14"
                        BorderThickness="0 0 0 1" BorderBrush="#E4E4E7">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="FileChartOutline" Width="16" Height="16"
                                         Foreground="#7C3AED" VerticalAlignment="Center"/>
                            <TextBlock Text="APPLICATIONS" FontSize="11" FontWeight="Bold"
                                       Foreground="#7C3AED" Margin="8 0 0 0" VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"/>
                        </StackPanel>
                        <TextBlock Text="Reports &amp; Printouts" FontSize="11"
                                   Foreground="#71717A" Margin="0 3 0 0"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- Footer -->
                <Border DockPanel.Dock="Bottom"
                        Padding="6 8" BorderThickness="0 1 0 0" BorderBrush="#E4E4E7">
                    <Button Style="{StaticResource BackNavButton}"
                            Command="{Binding DataContext.NavigateCommand,
                                RelativeSource={RelativeSource FindAncestor,
                                AncestorType={x:Type dashboardViews:DashboardView}}}"
                            CommandParameter="Home">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ArrowLeft" Width="15" Height="15"
                                         Margin="0 0 8 0" VerticalAlignment="Center"
                                         Foreground="#EF4444"/>
                            <TextBlock Text="Back to Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Nav items -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0 8 0 0">
                        <TextBlock Text="REPORTS" FontSize="10" FontWeight="Bold"
                                   Foreground="#A1A1AA" Margin="16 10 0 4"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"/>

                        <Button Style="{StaticResource SubNavButton}"
                                Command="{Binding NavigateReportCommand}" CommandParameter="ClassWiseStudents">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="AccountGroup" Width="15" Height="15"
                                             Margin="0 0 10 0" VerticalAlignment="Center" Foreground="#7C3AED"/>
                                <TextBlock Text="Class Wise Students" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SubNavButton}"
                                Command="{Binding NavigateReportCommand}" CommandParameter="ClassWiseSubjectCode">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="BookOpenPageVariant" Width="15" Height="15"
                                             Margin="0 0 10 0" VerticalAlignment="Center" Foreground="#7C3AED"/>
                                <TextBlock Text="Class Wise Subject Code" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SubNavButton}"
                                Command="{Binding NavigateReportCommand}" CommandParameter="ClassInternalMarkReport">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="ClipboardText" Width="15" Height="15"
                                             Margin="0 0 10 0" VerticalAlignment="Center" Foreground="#F97316"/>
                                <TextBlock Text="Class Int. Mark Report" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SubNavButton}"
                                Command="{Binding NavigateReportCommand}" CommandParameter="ClassWiseHallTicket">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="CardAccountDetails" Width="15" Height="15"
                                             Margin="0 0 10 0" VerticalAlignment="Center" Foreground="#22C55E"/>
                                <TextBlock Text="Class Wise Hall Ticket" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SubNavButton}"
                                Command="{Binding NavigateReportCommand}" CommandParameter="TimetablePrint">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="CalendarClock" Width="15" Height="15"
                                             Margin="0 0 10 0" VerticalAlignment="Center" Foreground="#3B82F6"/>
                                <TextBlock Text="Timetable Print" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SubNavButton}"
                                Command="{Binding NavigateReportCommand}" CommandParameter="YearWiseIntExtReport">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="ChartBar" Width="15" Height="15"
                                             Margin="0 0 10 0" VerticalAlignment="Center" Foreground="#F97316"/>
                                <TextBlock Text="Year Wise Int/Ext Report" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SubNavButton}"
                                Command="{Binding NavigateReportCommand}" CommandParameter="ClassWiseIntExtReport">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="ChartBoxOutline" Width="15" Height="15"
                                             Margin="0 0 10 0" VerticalAlignment="Center" Foreground="#7C3AED"/>
                                <TextBlock Text="Class Wise Int/Ext Report" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SubNavButton}"
                                Command="{Binding NavigateReportCommand}" CommandParameter="A4ResultPrint">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Printer" Width="15" Height="15"
                                             Margin="0 0 10 0" VerticalAlignment="Center" Foreground="#52525B"/>
                                <TextBlock Text="A4 Result Print" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SubNavButton}"
                                Command="{Binding NavigateReportCommand}" CommandParameter="RevaluationReport">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="FileRefresh" Width="15" Height="15"
                                             Margin="0 0 10 0" VerticalAlignment="Center" Foreground="#EF4444"/>
                                <TextBlock Text="Revaluation Report" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SubNavButton}"
                                Command="{Binding NavigateReportCommand}" CommandParameter="PassingCreditReport">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="CheckDecagram" Width="15" Height="15"
                                             Margin="0 0 10 0" VerticalAlignment="Center" Foreground="#22C55E"/>
                                <TextBlock Text="Passing Credit Report" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ── Content Area ─────────────────────────────────── -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentReportView}" Margin="28 24"/>
    </Grid>
</UserControl>
