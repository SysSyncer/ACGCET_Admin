<UserControl x:Class="ACGCET_Admin.Views.Application.PassingCreditReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:ACGCET_Admin.ViewModels.Application"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:PassingCreditReportViewModel}"
             d:DesignHeight="700" d:DesignWidth="1024">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="Transparent" Margin="16">
        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                     IsIndeterminate="True" Value="0" Width="50" Height="50"
                     Panel.ZIndex="100" VerticalAlignment="Center" HorizontalAlignment="Center"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <Grid IsEnabled="{Binding IsNotLoading}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filters -->
            <StackPanel Grid.Row="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Exam Time" VerticalAlignment="Center" Margin="0 0 16 0" FontWeight="Bold"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Examinations}" SelectedItem="{Binding SelectedExamination}" Margin="0 4"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Program" VerticalAlignment="Center" Margin="32 0 16 0" FontWeight="Bold"/>
                    <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding Programs}" SelectedItem="{Binding SelectedProgram}" Margin="0 4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Regulation" VerticalAlignment="Center" Margin="0 0 16 0" FontWeight="Bold"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Regulations}" SelectedItem="{Binding SelectedRegulation}" Margin="0 4"/>
                </Grid>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 16">
                <Button Command="{Binding ViewReportCommand}" Content="VIEW" Style="{StaticResource PrimaryButton}" Width="80" Margin="4"/>
                <Button Command="{Binding ClearFiltersCommand}" Content="CLEAR" Style="{StaticResource SubtleButton}" Width="80" Margin="4"/>
                <Button Command="{Binding RefreshCommand}" Style="{StaticResource IconButton}" ToolTip="Refresh" Margin="8 0 0 0">
                    <materialDesign:PackIcon Kind="Refresh" Width="14" Height="14"/>
                </Button>
            </StackPanel>

            <!-- DataGrid -->
            <DataGrid Grid.Row="2" ItemsSource="{Binding CreditData}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="S.No" Binding="{Binding SNo}" Width="60"/>
                    <DataGridTextColumn Header="Reg. No" Binding="{Binding RegistrationNumber}" Width="150"/>
                    <DataGridTextColumn Header="Student Name" Binding="{Binding StudentName}" Width="*"/>
                    <DataGridTextColumn Header="Total Credits" Binding="{Binding TotalCredits}" Width="120"/>
                    <DataGridTextColumn Header="Passed Credits" Binding="{Binding PassedCredits}" Width="120"/>
                    <DataGridTextColumn Header="Failed Credits" Binding="{Binding FailedCredits}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
