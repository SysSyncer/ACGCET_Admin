<UserControl x:Class="ACGCET_Admin.Views.Application.ClassWiseSubjectCodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:ACGCET_Admin.ViewModels.Application"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:ClassWiseSubjectCodeViewModel}"
             d:DesignHeight="700" d:DesignWidth="1024">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="Transparent" Margin="16">
        <!-- Loading Overlay -->
        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                     IsIndeterminate="True" Value="0" Width="50" Height="50"
                     Panel.ZIndex="100" VerticalAlignment="Center" HorizontalAlignment="Center"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <Grid IsEnabled="{Binding IsNotLoading}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Filters -->
                <RowDefinition Height="Auto"/> <!-- Actions -->
                <RowDefinition Height="*"/>    <!-- DataGrid -->
            </Grid.RowDefinitions>

            <!-- Filters -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.Resources>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignBody2TextBlock}">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="0 0 16 0"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                    </Style>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                        <Setter Property="Margin" Value="0 4"/>
                        <Setter Property="Width" Value="200"/>
                    </Style>
                </Grid.Resources>

                <!-- Filter Inputs -->
                <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0 8">
                        <TextBlock Text="Regulation" Width="100"/>
                        <ComboBox ItemsSource="{Binding Regulations}" SelectedItem="{Binding SelectedRegulation}"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0 8">
                        <TextBlock Text="Program Name" Width="100"/>
                        <ComboBox ItemsSource="{Binding Programs}" SelectedItem="{Binding SelectedProgram}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0 0 0 16">
                     <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding ViewReportCommand}" Content="VIEW" Style="{StaticResource PrimaryButton}" Width="80" Margin="4"/>
                        <Button Command="{Binding PreviewCommand}" Content="PREVIEW" Style="{StaticResource SubtleButton}" Width="100" Margin="4"/>
                        <Button Command="{Binding PrintCommand}" Content="PRINT" Style="{StaticResource SubtleButton}" Width="80" Margin="4"/>
                        <Button Command="{Binding ClearFiltersCommand}" Content="CLEAR" Style="{StaticResource SubtleButton}" Width="80" Margin="4"/>
                        <Button Command="{Binding RefreshCommand}" Style="{StaticResource IconButton}" ToolTip="Refresh" Margin="8 0 0 0">
                            <materialDesign:PackIcon Kind="Refresh" Width="14" Height="14"/>
                        </Button>
                     </StackPanel>
                </StackPanel>
            </Grid>

            <!-- DataGrid -->
            <DataGrid Grid.Row="2" ItemsSource="{Binding SubjectsList}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Semester}" Header="Sem"/>
                    <DataGridTextColumn Binding="{Binding PaperCode}" Header="Code"/>
                    <DataGridTextColumn Binding="{Binding PaperName}" Header="Paper Name" Width="*"/>
                    <DataGridTextColumn Binding="{Binding Credits}" Header="Cred"/>
                    <DataGridTextColumn Binding="{Binding IntMax}" Header="Int"/>
                    <DataGridTextColumn Binding="{Binding ExtMax}" Header="Ext"/>
                    <DataGridTextColumn Binding="{Binding TotalMax}" Header="Tot"/>
                    <DataGridTextColumn Binding="{Binding IntMin}" Header="P.Int"/>
                    <DataGridTextColumn Binding="{Binding ExtMin}" Header="P.Ext"/>
                    <DataGridTextColumn Binding="{Binding TotalMin}" Header="P.Tot"/>
                    <DataGridTextColumn Binding="{Binding Type}" Header="Type"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
