<UserControl x:Class="ACGCET_Admin.Views.AdminControl.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ACGCET_Admin.ViewModels.AdminControl"
             d:DataContext="{d:DesignInstance Type=vm:UserManagementViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BTV"/>
        <md:NullableToVisibilityConverter x:Key="NullableToVisibility"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
            <RowDefinition Height="*"/>     <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0 0 0 16">
            <md:PackIcon Kind="AccountMultiple" Width="28" Height="28"
                         Foreground="#4A148C" VerticalAlignment="Center"
                         DockPanel.Dock="Left" Margin="0 0 10 0"/>
            <TextBlock Text="User Management" VerticalAlignment="Center"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       Foreground="#4A148C"/>
            <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                    Command="{Binding ShowAddFormCommand}"
                    Background="#4A148C" Foreground="White"
                    md:ButtonAssist.CornerRadius="8"
                    Height="40" Padding="16 0"
                    IsEnabled="{Binding IsNotLoading}">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="AccountPlus" Width="18" Height="18"
                                 VerticalAlignment="Center" Margin="0 0 6 0"/>
                    <TextBlock Text="Add User" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
        </DockPanel>

        <!-- Status Bar -->
        <Border Grid.Row="1" Margin="0 0 0 12" CornerRadius="6" Padding="12 8"
                Visibility="{Binding StatusMessage, Converter={StaticResource NullableToVisibility}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#E8F5E9"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                            <Setter Property="Background" Value="#FFEBEE"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Width="16" Height="16" VerticalAlignment="Center" Margin="0 0 8 0">
                    <md:PackIcon.Style>
                        <Style TargetType="md:PackIcon">
                            <Setter Property="Kind" Value="CheckCircle"/>
                            <Setter Property="Foreground" Value="#388E3C"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                    <Setter Property="Kind" Value="AlertCircle"/>
                                    <Setter Property="Foreground" Value="#D32F2F"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </md:PackIcon.Style>
                </md:PackIcon>
                <TextBlock Text="{Binding StatusMessage}" FontSize="13" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#2E7D32"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                    <Setter Property="Foreground" Value="#C62828"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Users DataGrid -->
            <md:Card Grid.Column="0" md:ShadowAssist.ShadowDepth="Depth0"
                     UniformCornerRadius="8" Margin="0 0 16 0"
                     BorderThickness="1" BorderBrush="#E0E0E0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              md:DataGridAssist.ColumnHeaderPadding="12 8"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Full Name"   Binding="{Binding FullName}"   Width="*" MinWidth="120"/>
                            <DataGridTextColumn Header="Username"    Binding="{Binding UserName}"   Width="100"/>
                            <DataGridTextColumn Header="Email"       Binding="{Binding Email}"      Width="160"/>
                            <DataGridTextColumn Header="Department"  Binding="{Binding Department}" Width="120"/>
                            <DataGridTextColumn Header="Role(s)"     Binding="{Binding Roles}"      Width="120"/>
                            <DataGridCheckBoxColumn Header="Active"  Binding="{Binding IsActive}"   Width="60"/>
                            <DataGridCheckBoxColumn Header="Locked"  Binding="{Binding IsLocked}"   Width="60"/>
                            <DataGridTemplateColumn Header="Actions" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Command="{Binding DataContext.ToggleActiveCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    ToolTip="Toggle Active"
                                                    Width="32" Height="32" Padding="0">
                                                <md:PackIcon Kind="AccountCheck" Width="16" Height="16" Foreground="#4A148C"/>
                                            </Button>
                                            <Button Command="{Binding DataContext.UnlockUserCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    ToolTip="Unlock Account"
                                                    Width="32" Height="32" Padding="0"
                                                    IsEnabled="{Binding IsLocked}">
                                                <md:PackIcon Kind="LockOpen" Width="16" Height="16" Foreground="#388E3C"/>
                                            </Button>
                                            <Button Command="{Binding DataContext.RemoveUserCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    ToolTip="Remove User"
                                                    Width="32" Height="32" Padding="0">
                                                <md:PackIcon Kind="AccountRemove" Width="16" Height="16" Foreground="#D32F2F"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Loading overlay -->
                    <Border Grid.Row="0" Background="#88FFFFFF"
                            Visibility="{Binding IsLoading, Converter={StaticResource BTV}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         IsIndeterminate="True" Value="0"
                                         Width="40" Height="40" Foreground="#4A148C"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </md:Card>

            <!-- Add User Form Panel -->
            <md:Card Grid.Column="1" Width="300"
                     md:ShadowAssist.ShadowDepth="Depth0"
                     UniformCornerRadius="8"
                     BorderThickness="1" BorderBrush="#E0E0E0"
                     Visibility="{Binding IsAddingUser, Converter={StaticResource BTV}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Add New User" FontSize="16" FontWeight="Bold"
                                   Foreground="#4A148C" Margin="0 0 0 16"/>

                        <TextBox Text="{Binding NewFullName, UpdateSourceTrigger=PropertyChanged}"
                                 md:HintAssist.Hint="Full Name *"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0 0 0 12"/>
                        <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"
                                 md:HintAssist.Hint="Username *"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0 0 0 12"/>
                        <TextBox Text="{Binding NewEmail, UpdateSourceTrigger=PropertyChanged}"
                                 md:HintAssist.Hint="Email Address"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0 0 0 12"/>
                        <TextBox Text="{Binding NewDepartment, UpdateSourceTrigger=PropertyChanged}"
                                 md:HintAssist.Hint="Department"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0 0 0 12"/>
                        <TextBox Text="{Binding NewDesignation, UpdateSourceTrigger=PropertyChanged}"
                                 md:HintAssist.Hint="Designation"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0 0 0 12"/>
                        <PasswordBox x:Name="pbNewUser"
                                     md:HintAssist.Hint="Password * (min. 6)"
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     Margin="0 0 0 12"
                                     PasswordChanged="NewUserPassword_Changed"/>

                        <TextBlock Text="Assign Role" FontSize="12" Foreground="#757575"
                                   Margin="0 0 0 4"/>
                        <ComboBox ItemsSource="{Binding AvailableRoles}"
                                  SelectedItem="{Binding NewRole}"
                                  DisplayMemberPath="RoleName"
                                  Margin="0 0 0 20"/>

                        <Button Command="{Binding SaveNewUserCommand}"
                                IsEnabled="{Binding IsNotLoading}"
                                Background="#4A148C" Foreground="White"
                                md:ButtonAssist.CornerRadius="8"
                                Height="44" FontWeight="Bold" Margin="0 0 0 8">
                            SAVE USER
                        </Button>
                        <Button Command="{Binding CancelAddCommand}"
                                Style="{StaticResource SubtleButton}"
                                Foreground="#4A148C" BorderBrush="#4A148C"
                                md:ButtonAssist.CornerRadius="8" Height="44">
                            CANCEL
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </md:Card>
        </Grid>
    </Grid>
</UserControl>
