<UserControl x:Class="ACGCET_Admin.Views.Dashboard.ForgotPasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ACGCET_Admin.ViewModels.Dashboard"
             d:DataContext="{d:DesignInstance Type=vm:ForgotPasswordViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BTV"/>
        <Style x:Key="FPTextBox" TargetType="TextBox"
               BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Margin" Value="0 0 0 16"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="FPPasswordBox" TargetType="PasswordBox"
               BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}">
            <Setter Property="Margin" Value="0 0 0 16"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Background" Value="#4A148C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="md:ButtonAssist.CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0 4 0 0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" MinWidth="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Forgot Password Form -->
        <Grid Grid.Column="0" Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="44 48 44 48">

                    <!-- Brand -->
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 36">
                        <Image Source="pack://application:,,,/Resources/Images/acgcet_logo.png"
                               Width="48" Height="48" VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel Margin="12 0 0 0" VerticalAlignment="Center">
                            <TextBlock Text="ACGCET" FontSize="16" FontWeight="Bold"
                                       Foreground="#4A148C"/>
                            <TextBlock Text="COE Admin Portal" FontSize="11" Foreground="#757575"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Step indicators -->
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 28">
                        <Ellipse Width="28" Height="28">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#E0D6F0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStep1}" Value="True">
                                            <Setter Property="Fill" Value="#4A148C"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                   FontWeight="Bold" FontSize="12" Foreground="White"
                                   Margin="-18 0 8 0"/>
                        <Rectangle Height="2" Width="32" Fill="#E0D6F0" VerticalAlignment="Center" Margin="0 0 0 0"/>
                        <Ellipse Width="28" Height="28" Margin="0 0 0 0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#E0D6F0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStep2}" Value="True">
                                            <Setter Property="Fill" Value="#4A148C"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                                   FontWeight="Bold" FontSize="12" Foreground="White"
                                   Margin="-18 0 8 0"/>
                        <Rectangle Height="2" Width="32" Fill="#E0D6F0" VerticalAlignment="Center"/>
                        <Ellipse Width="28" Height="28">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#E0D6F0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                            <Setter Property="Fill" Value="#4A148C"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="3" VerticalAlignment="Center" HorizontalAlignment="Center"
                                   FontWeight="Bold" FontSize="12" Foreground="White"
                                   Margin="-18 0 0 0"/>
                    </StackPanel>

                    <!-- STEP 1: Enter Username -->
                    <StackPanel Visibility="{Binding IsStep1, Converter={StaticResource BTV}}">
                        <TextBlock Text="Forgot Password?" FontSize="26" FontWeight="Bold"
                                   Foreground="#1C1B1F" Margin="0 0 0 6"/>
                        <TextBlock Text="Enter your admin username. We'll send an OTP to the email registered with your account."
                                   FontSize="13" Foreground="#49454F"
                                   TextWrapping="Wrap" Margin="0 0 0 28"/>

                        <TextBlock Text="Username" FontSize="12" FontWeight="Medium"
                                   Foreground="#49454F" Margin="0 0 0 4"/>
                        <TextBox Text="{Binding UsernameInput, UpdateSourceTrigger=PropertyChanged}"
                                 md:HintAssist.Hint="Your admin username"
                                 Style="{StaticResource FPTextBox}"
                                 IsEnabled="{Binding IsNotLoading}"/>

                        <Button Command="{Binding SendOtpCommand}"
                                IsEnabled="{Binding IsNotLoading}"
                                Style="{StaticResource PrimaryBtn}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="EmailSend" Width="20" Height="20"
                                             VerticalAlignment="Center" Margin="0 0 8 0"/>
                                <TextBlock Text="SEND OTP" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- STEP 2: Verify OTP -->
                    <StackPanel Visibility="{Binding IsStep2, Converter={StaticResource BTV}}">
                        <TextBlock Text="Enter OTP" FontSize="26" FontWeight="Bold"
                                   Foreground="#1C1B1F" Margin="0 0 0 6"/>
                        <TextBlock FontSize="13" Foreground="#49454F"
                                   TextWrapping="Wrap" Margin="0 0 0 28">
                            <Run Text="An OTP was sent to "/>
                            <Run Text="{Binding EmailHint}" FontWeight="Bold" Foreground="#4A148C"/>
                            <Run Text=". Enter it below."/>
                        </TextBlock>

                        <TextBlock Text="One-Time Password" FontSize="12" FontWeight="Medium"
                                   Foreground="#49454F" Margin="0 0 0 4"/>
                        <TextBox Text="{Binding OtpInput, UpdateSourceTrigger=PropertyChanged}"
                                 md:HintAssist.Hint="6-digit OTP"
                                 Style="{StaticResource FPTextBox}"
                                 IsEnabled="{Binding IsNotLoading}"
                                 MaxLength="6" FontSize="20" TextAlignment="Center"/>

                        <Button Command="{Binding VerifyOtpCommand}"
                                IsEnabled="{Binding IsNotLoading}"
                                Style="{StaticResource PrimaryBtn}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="ShieldCheck" Width="20" Height="20"
                                             VerticalAlignment="Center" Margin="0 0 8 0"/>
                                <TextBlock Text="VERIFY OTP" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding BackToStep1Command}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#4A148C" Height="36" Margin="0 8 0 0">
                            Resend OTP / Back
                        </Button>
                    </StackPanel>

                    <!-- STEP 3: New Password -->
                    <StackPanel Visibility="{Binding IsStep3, Converter={StaticResource BTV}}">
                        <TextBlock Text="New Password" FontSize="26" FontWeight="Bold"
                                   Foreground="#1C1B1F" Margin="0 0 0 6"/>
                        <TextBlock Text="OTP verified. Set a new strong password for your account."
                                   FontSize="13" Foreground="#49454F"
                                   TextWrapping="Wrap" Margin="0 0 0 28"/>

                        <TextBlock Text="New Password" FontSize="12" FontWeight="Medium"
                                   Foreground="#49454F" Margin="0 0 0 4"/>
                        <PasswordBox x:Name="pbNew" md:HintAssist.Hint="Min. 6 characters"
                                     Style="{StaticResource FPPasswordBox}"
                                     IsEnabled="{Binding IsNotLoading}"
                                     PasswordChanged="NewPassword_Changed"/>

                        <TextBlock Text="Confirm Password" FontSize="12" FontWeight="Medium"
                                   Foreground="#49454F" Margin="0 0 0 4"/>
                        <PasswordBox x:Name="pbConfirm" md:HintAssist.Hint="Re-enter password"
                                     Style="{StaticResource FPPasswordBox}"
                                     IsEnabled="{Binding IsNotLoading}"
                                     PasswordChanged="ConfirmPassword_Changed"/>

                        <Button Command="{Binding ResetPasswordCommand}"
                                IsEnabled="{Binding IsNotLoading}"
                                Style="{StaticResource PrimaryBtn}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="LockReset" Width="20" Height="20"
                                             VerticalAlignment="Center" Margin="0 0 8 0"/>
                                <TextBlock Text="RESET PASSWORD" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Status Messages (shared across steps) -->
                    <Border CornerRadius="8" Padding="12 10" Margin="0 16 0 0"
                            Background="#FFEBEE"
                            Visibility="{Binding IsErrorVisible, Converter={StaticResource BTV}}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="AlertCircleOutline" Foreground="#C62828"
                                         Width="18" Height="18" VerticalAlignment="Center" Margin="0 0 8 0"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#B71C1C"
                                       FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="8" Padding="12 10" Margin="0 16 0 0"
                            Background="#E8F5E9"
                            Visibility="{Binding IsSuccessVisible, Converter={StaticResource BTV}}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="CheckCircleOutline" Foreground="#2E7D32"
                                         Width="18" Height="18" VerticalAlignment="Center" Margin="0 0 8 0"/>
                            <TextBlock Text="{Binding SuccessMessage}" Foreground="#1B5E20"
                                       FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Loading -->
                    <StackPanel HorizontalAlignment="Center" Margin="0 16 0 0"
                                Visibility="{Binding IsLoading, Converter={StaticResource BTV}}">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     IsIndeterminate="True" Value="0"
                                     Width="36" Height="36" Foreground="#4A148C"/>
                    </StackPanel>

                    <!-- Back to Login -->
                    <Button Command="{Binding BackToLoginCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="#757575" Height="36" Margin="0 20 0 0"
                            HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ArrowLeft" Width="16" Height="16"
                                         VerticalAlignment="Center" Margin="0 0 4 0"/>
                            <TextBlock Text="Back to Login" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </ScrollViewer>
            <Rectangle Width="4" HorizontalAlignment="Right" Fill="#4A148C"/>
        </Grid>

        <!-- RIGHT PANEL: same college image -->
        <Grid Grid.Column="1" ClipToBounds="True">
            <Image Source="pack://application:,,,/Resources/Images/college_building.jpg"
                   Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
            <Rectangle Fill="#CC190030"/>
            <StackPanel VerticalAlignment="Bottom" Margin="48 0 48 56">
                <TextBlock FontSize="30" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" LineHeight="40">
                    Alagappa Chettiar Government&#10;College of Engineering and Technology
                </TextBlock>
                <TextBlock Text="Karaikudi — 630 003, Tamil Nadu"
                           FontSize="14" Foreground="#CCFFFFFF" Margin="0 10 0 0"/>
                <Rectangle Height="2" Width="120" HorizontalAlignment="Left"
                           Fill="#994A148C" Margin="0 16 0 16"/>
                <TextBlock Text="Integrity  ·  Industry  ·  Enterprise"
                           FontSize="12" Foreground="#AAFFFFFF" FontStyle="Italic"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
