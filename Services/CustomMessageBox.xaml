<Window x:Class="ACGCET_Admin.Services.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Message" Height="200" Width="400" 
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" 
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">
    
    <Border Background="White" CornerRadius="10" BorderBrush="{DynamicResource PrimaryHueMidBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}" CornerRadius="9 9 0 0" Padding="10">
                <TextBlock x:Name="TitleText" Text="Notification" Foreground="White" FontWeight="Bold" FontSize="16"/>
            </Border>

            <!-- Content -->
            <TextBlock x:Name="MessageText" Grid.Row="1" Text="Message goes here..." 
                       VerticalAlignment="Center" HorizontalAlignment="Center" 
                       TextWrapping="Wrap" Margin="20" FontSize="14"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                <Button x:Name="OkButton" Content="OK" Click="OkButton_Click" 
                        Style="{StaticResource MaterialDesignFlatButton}" Margin="5"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
